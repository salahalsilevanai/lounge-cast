{
    "manifest_version": 3,
    "name": "osnTogetherExtention",
    "version": "1.0.0",
    "content_scripts": [
        {
            "matches": [
                "https://osnplus.com/*","https://www.youtube.com/*"],
            "js": ["Content.js"]
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}